{
  "name": "astra-membership-requests-frontend",
  "version": "0.7.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "e2e": "playwright test",
    "e2e:auth-profile": "playwright test e2e/auth-profile.spec.ts --project=chromium",
    "e2e:install": "playwright install chromium",
    "test": "vitest run",
    "typecheck": "vue-tsc --noEmit && tsc --noEmit -p tsconfig.playwright.json",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@sentry/browser": "^10.52.0",
    "vue": "3.5.32"
  },
  "devDependencies": {
    "@playwright/test": "1.55.0",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "5.2.4",
    "@vue/test-utils": "2.4.6",
    "jsdom": "26.1.0",
    "typescript": "5.8.3",
    "vite": "5.4.19",
    "vitest": "1.6.1",
    "vue-tsc": "2.2.12"
  }
}
