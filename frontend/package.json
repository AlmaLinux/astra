{
  "name": "astra-membership-requests-frontend",
  "version": "0.7.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "e2e": "playwright test --project=chromium",
    "e2e:raw": "playwright test",
    "e2e:auth": "playwright test e2e/auth --project=chromium",
    "e2e:auth-profile": "playwright test e2e/auth --project=chromium",
    "e2e:membership-committee": "playwright test e2e/membership/committee-queue.spec.ts --project=chromium",
    "e2e:membership-invitations": "playwright test e2e/membership/account-invitations.spec.ts --project=chromium",
    "e2e:organizations": "playwright test e2e/organizations/list-detail.spec.ts e2e/organizations/claim.spec.ts --project=chromium",
    "e2e:groups": "playwright test e2e/groups/list-detail.spec.ts e2e/groups/management.spec.ts --project=chromium",
    "e2e:elections": "playwright test e2e/elections/list-detail.spec.ts e2e/elections/routes-shell.spec.ts e2e/elections/ballot-verify.spec.ts e2e/elections/lifecycle.spec.ts --project=chromium --workers=1",
    "e2e:membership-settings": "../scripts/auth-profile-e2e.sh run --theme membership-settings --no-rebuild",
    "e2e:membership-settings:playwright": "playwright test e2e/membership/settings-membership.spec.ts --project=chromium",
    "e2e:mail-tools": "playwright test e2e/mail-tools.spec.ts --project=chromium",
    "e2e:shell-routes": "playwright test e2e/shell-routes.spec.ts --project=chromium",
    "e2e:reports-admin": "playwright test e2e/reports-admin.spec.ts --project=chromium",
    "e2e:membership-self-service": "playwright test e2e/membership/self-service-entry.spec.ts e2e/membership/self-service-detail.spec.ts --project=chromium",
    "e2e:wave1": "playwright test e2e/auth --project=chromium",
    "e2e:install": "playwright install chromium",
    "test": "vitest run",
    "typecheck": "vue-tsc --noEmit && tsc --noEmit -p tsconfig.playwright.json",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@sentry/browser": "^10.52.0",
    "vue": "3.5.32"
  },
  "devDependencies": {
    "@playwright/test": "1.55.0",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "5.2.4",
    "@vue/test-utils": "2.4.6",
    "jsdom": "26.1.0",
    "typescript": "5.8.3",
    "vite": "5.4.19",
    "vitest": "1.6.1",
    "vue-tsc": "2.2.12"
  }
}
